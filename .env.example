# Snowflake — the app. The PAT is role-locked at creation; see docs/snowflake-setup.md.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PAT=
SNOWFLAKE_WAREHOUSE=CHRONICLES_WH
SNOWFLAKE_DATABASE=CHRONICLES
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=ACCOUNTADMIN

# GitHub token. Used only to mint the Snowflake SECRET the ingest proc reads —
# Cloud Run never calls GitHub itself.
GITHUB_TOKEN=

# Cloud Run
PORT=8080
CARD_BUCKET=
PUBLIC_ORIGIN=https://commitchronicles.dev

# Cost guards. The cap is a hard ceiling on live generations per day, counted in the
# bucket so it holds across instances.
DAILY_GENERATION_CAP=100
GENERATING_TTL_SECONDS=600
