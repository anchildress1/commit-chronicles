auto-install-peers=true
strict-peer-dependencies=false

# The actual pnpm cooldown guard lives in pnpm-workspace.yaml
# (minimumReleaseAge / minimumReleaseAgeExclude) — that's the canonical
# location for pnpm 10+. This npm-CLI key is a no-op under pnpm; kept only
# so plain `npm` and npm-aware scanners still see a cooldown configured.
min-release-age=7
