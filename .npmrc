auto-install-peers=true
strict-peer-dependencies=false

# Supply-chain guard: refuse dependency versions published less than 7 days ago,
# so a compromised fresh publish can't land in an install before it's caught.
# npm CLI key (unit: days):
min-release-age=7
# pnpm key (unit: minutes) — the one that actually governs `pnpm install` here:
minimum-release-age=10080
# First-party Cloudflare types publish daily and are date-versioned, so they'd
# never satisfy their range under a cooldown — exclude them.
minimum-release-age-exclude[]=@cloudflare/workers-types
